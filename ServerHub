    frame:TweenPosition(UDim2.new(1, -310, 1, -60), "Out", "Quad", 0.3)
    task.wait(3)
    frame:TweenPosition(UDim2.new(1, 10, 1, -60), "Out", "Quad", 0.3)
    task.wait(0.3)
    gui:Destroy()
end

local oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    if method == "FireServer" and tostring(self):lower():find("anticheat") then
        return nil
    end
    return oldNamecall(self, ...)
end)

local hyperActive = false
local hyperConn = nil

local function toggleHyper()
    hyperActive = not hyperActive
    if hyperActive then
        local mouse = Player:GetMouse()
        hyperConn = mouse.Button1Down:Connect(function()
            local target = mouse.Target
            if target and target:IsA("BasePart") and target ~= Player.Character then
                local occupants = {}
                for _, other in ipairs(Players:GetPlayers()) do
                    if other ~= Player and other.Character and other.Character:FindFirstChild("HumanoidRootPart") then
                        local root = other.Character.HumanoidRootPart
                        if root and (root.Position - target.Position).Magnitude < 10 then
                            table.insert(occupants, other)
                        end
                    end
                end
                target:Destroy()
                Notify("Hyper Tool", "Уничтожено: " .. target.Name, Color3.fromRGB(255,100,0))
                for _, victim in ipairs(occupants) do
                    if victim.Character and victim.Character:FindFirstChild("HumanoidRootPart") then
                        victim.Character.HumanoidRootPart.CFrame = victim.Character.HumanoidRootPart.CFrame + Vector3.new(0, -15, 0)
                        Notify("Hyper Tool", victim.Name .. " выпал", Color3.fromRGB(255,100,0))
                    end
                end
            end
        end)
        Notify("Hyper Tool", "Активирован | Кликай по постройкам", Color3.fromRGB(0,255,0))
    else
        if hyperConn then hyperConn:Disconnect() end
        Notify("Hyper Tool", "Деактивирован", Color3.fromRGB(255,0,0))
    end
end

local rainbowActive = false
local rainbowTask = nil

local function toggleRainbow()
    rainbowActive = not rainbowActive
    if rainbowActive then
        rainbowTask = task.spawn(function()
            local hue = 0
            while rainbowActive and task.wait(0.1) do
                if Player.Character and Player.Character:FindFirstChild("Humanoid") then
                    Player.Character.Humanoid.NameColor3 = Color3.fromHSV(hue, 1, 1)
                    hue = hue + 0.02
                    if hue > 1 then hue = 0 end
                end
            end
        end)
        Notify("Rainbow Name", "Включён", Color3.fromRGB(0,255,0))
    else
        if rainbowTask then task.cancel(rainbowTask) end
        if Player.Character and Player.Character:FindFirstChild("Humanoid") then
            Player.Character.Humanoid.NameColor3 = Color3.fromRGB(255,255,255)
        end
        Notify("Rainbow Name", "Выключен", Color3.fromRGB(255,0,0))
    end
end

local ghostActive = false
local originalName = nil

local function toggleGhost()
    ghostActive = not ghostActive
    if ghostActive then
        if Player.Character and Player.Character:FindFirstChild("Humanoid") then
            originalName = Player.Character.Humanoid.DisplayName
            Player.Character.Humanoid.DisplayName = Config.fakeName
        end
        Notify("Ghost Mode", "Теперь вы: " .. Config.fakeName, Color3.fromRGB(0,255,0))
    else
        if Player.Character and Player.Character:FindFirstChild("Humanoid") and originalName then
            Player.Character.Humanoid.DisplayName = originalName
        end
        Notify("Ghost Mode", "Выключен", Color3.fromRGB(255,0,0))
    end
end

